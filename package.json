{
    "name": "levis-judex",
    "version": "0.7.0",
    "description": "Self-hosted platform running on Express.js (prettified with tailwind css) for creating contests/problems like codeforces & usaco.org that uses ioi's isolate software to sandbox submissions.",
    "main": "src/index.ts",
    "scripts": {
        "dev": "tsx --watch --env-file .env src/index.ts",
        "docs": "npx typedoc",
        "build": "tsc",
        "start": "npm run build && node --env-file .env dist/index.js",
        "type-check": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "create:test-user": "tsx --env-file .env src/scripts/create-test-user.ts",
        "migrate:database": "tsx --env-file .env src/scripts/migrate-database.ts",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "node --import tsx --test tests/**/*.test.ts"
    },
    "keywords": [],
    "author": "Code Joint (https://codejoint.org)",
    "license": "GPL-3.0-only",
    "dependencies": {
        "bcryptjs": "^3.0.3",
        "body-parser": "^1.20.5",
        "child_process": "^1.0.2",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "disposable-email-domains": "^1.0.62",
        "dotenv": "^16.6.1",
        "ejs": "^3.1.10",
        "express": "^4.22.2",
        "express-async-errors": "^3.1.1",
        "express-ejs-layouts": "^2.5.1",
        "express-rate-limit": "^8.5.2",
        "express-slow-down": "^3.1.0",
        "fs": "^0.0.1-security",
        "helmet": "^7.1.0",
        "jsdom": "^26.1.0",
        "jsonwebtoken": "^9.0.3",
        "mongod": "^2.0.0",
        "mongoose": "^8.24.0",
        "nodemailer": "^8.0.11",
        "sanitize-html": "^2.17.5",
        "validator": "^13.15.35"
    },
    "devDependencies": {
        "@tsconfig/node22": "^22.0.5",
        "@types/body-parser": "^1.19.6",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/ejs": "^3.1.5",
        "@types/express": "^5.0.6",
        "@types/express-ejs-layouts": "^2.5.4",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/mongoose": "^5.11.96",
        "@types/node": "^24.13.2",
        "@types/nodemailer": "^8.0.1",
        "@types/sanitize-html": "^2.16.1",
        "@types/validator": "^13.15.10",
        "eslint": "^9.35.0",
        "eslint-plugin-perfectionist": "^4.15.1",
        "nodemon": "^3.1.14",
        "prettier": "^3.8.4",
        "tsx": "^4.22.4",
        "typedoc": "^0.28.19",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.61.0"
    }
}
