<div class="page narrow mx-auto">
    <section class="page-header">
        <div>
            <p class="page-kicker">Account</p>
            <h1 class="page-title">Reset password</h1>
            <p class="page-subtitle">Enter your email and we will send a reset link if the account exists.</p>
        </div>
    </section>

    <section class="panel panel-body">
        <form id="reset-form" class="space-y-5">
            <%- include("partials/input", { id: "email", label: "Email", type: "email", placeholder: "you@example.com" }) %>
            <%- include("partials/button", { id: "reset-button", text: "Send reset link" }) %>
        </form>
    </section>
</div>
