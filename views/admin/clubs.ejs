<div class="max-w-5xl mx-auto space-y-6">
    <div class="text-center">
        <h1 class="text-4xl font-bold text-white mb-2">Classes / Clubs</h1>
        <p class="text-gray-400">Create rosters for restricted contests</p>
    </div>

    <section class="bg-gray-700 rounded-lg p-6 border border-gray-600">
        <form id="club-form" class="grid grid-cols-1 gap-5">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                    <label for="club-id" class="text-lg font-semibold text-white mb-2 block">Class / Club ID</label>
                    <input id="club-id" required placeholder="e.g. algebra-club"
                        class="w-full text-lg p-3 rounded-lg bg-gray-600 text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 border border-gray-500">
                </div>
                <div>
                    <label for="club-name" class="text-lg font-semibold text-white mb-2 block">Name</label>
                    <input id="club-name" required placeholder="e.g. Algebra Programming Club"
                        class="w-full text-lg p-3 rounded-lg bg-gray-600 text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 border border-gray-500">
                </div>
            </div>
            <div>
                <label for="member-emails" class="text-lg font-semibold text-white mb-2 block">Student Emails</label>
                <textarea id="member-emails" rows="8" placeholder="one@example.com&#10;two@example.com"
                    class="w-full text-lg p-3 rounded-lg bg-gray-600 text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 border border-gray-500"></textarea>
            </div>
            <div class="text-center">
                <button class="text-lg px-5 py-3 rounded-lg bg-blue-500 text-white hover:bg-blue-600 focus:outline-none transition-colors duration-200">
                    Save Class / Club
                </button>
            </div>
        </form>
    </section>

    <section class="bg-gray-700 rounded-lg p-6 border border-gray-600">
        <h2 class="text-2xl font-bold text-white mb-4">Saved Rosters</h2>
        <div id="club-list" class="grid grid-cols-1 md:grid-cols-2 gap-4"></div>
    </section>
</div>
