<div class="page narrow mx-auto">
    <section class="page-header">
        <div>
            <p class="page-kicker">Admin</p>
            <h1 class="page-title">Admin access</h1>
            <p class="page-subtitle">Grant or revoke platform administrator privileges by email.</p>
        </div>
    </section>

    <section class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <form class="panel panel-body space-y-4">
            <div>
                <h2 class="section-heading">Grant access</h2>
                <p class="section-note">Promote a verified user to admin.</p>
            </div>
            <%- include("../partials/input", { id: "user-to-add", label: "User Email", type: "email", placeholder: "user@example.com" }) %>
            <%- include("../partials/button", { id: "add-button", small: true, text: "Grant admin" }) %>
        </form>

        <form class="panel panel-body space-y-4">
            <div>
                <h2 class="section-heading">Revoke access</h2>
                <p class="section-note">Remove admin privileges from a user.</p>
            </div>
            <%- include("../partials/input", { id: "user-to-remove", label: "User Email", type: "email", placeholder: "admin@example.com" }) %>
            <%- include("../partials/button", { id: "remove-button", small: true, text: "Revoke admin" }) %>
        </form>
    </section>
</div>
