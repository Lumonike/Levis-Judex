<link href="/admin/add-problem/sun-editor.css" rel="stylesheet" />
<script>
    window.contestEditorConfig = <%- JSON.stringify("contestEditorConfig" in locals ? contestEditorConfig : {}) %>;
</script>

<div class="page">
    <div class="page-header">
        <div>
            <p class="page-kicker">Contest Builder</p>
            <h1 class="page-title">Create or edit a contest</h1>
            <p class="page-subtitle">Set timing, access, points, and problems in one place.</p>
        </div>
        <div class="panel panel-body">
            <p class="section-note">Scoring</p>
            <p class="m-0 font-bold">Samples ignored; hidden tests split points.</p>
        </div>
    </div>

    <div class="panel panel-body">
        <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-4 items-end">
            <%- include("../partials/input", { id: "contest-id-search", label: "Contest ID to Edit", type: "text", placeholder: "e.g. dec-2026" }) %>
            <button id="load-contest-button" class="btn h-fit" type="button">
                Load Contest
            </button>
        </div>
    </div>

    <form id="contest-form" class="space-y-6">
        <div class="panel panel-body space-y-6">
            <div>
                <h2 class="section-heading">Contest Setup</h2>
                <p class="section-note">These settings control availability and scoring windows.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <%- include("../partials/input", { id: "id", label: "Contest ID", type: "text", placeholder: "e.g. dec-2026" }) %>
                <%- include("../partials/input", { id: "name", label: "Contest Name", type: "text", placeholder: "December Contest" }) %>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label for="start-time" class="text-lg font-semibold text-white mb-2 block">Open Time</label>
                    <input type="datetime-local" id="start-time" required
                        class="w-full text-lg p-3 rounded-lg bg-gray-600 text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 border border-gray-500"/>
                </div>
                <div>
                    <label for="end-time" class="text-lg font-semibold text-white mb-2 block">Close Time</label>
                    <input type="datetime-local" id="end-time" required
                        class="w-full text-lg p-3 rounded-lg bg-gray-600 text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 border border-gray-500"/>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label for="timing-mode" class="text-lg font-semibold text-white mb-2 block">Timing Mode</label>
                    <select id="timing-mode" class="w-full text-lg p-3 rounded-lg bg-gray-600 text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 border border-gray-500">
                        <option value="global">Global window</option>
                        <option value="personal">Personal timer</option>
                    </select>
                </div>
                <div id="duration-wrapper" class="hidden">
                    <label for="duration-minutes" class="text-lg font-semibold text-white mb-2 block">Duration Minutes</label>
                    <input type="number" id="duration-minutes" min="1" value="240"
                        class="w-full text-lg p-3 rounded-lg bg-gray-600 text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 border border-gray-500"/>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label for="access-type" class="text-lg font-semibold text-white mb-2 block">Who Can Enter?</label>
                    <select id="access-type" class="w-full text-lg p-3 rounded-lg bg-gray-600 text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 border border-gray-500">
                        <option value="public">Anyone</option>
                        <option value="club">Class / club members</option>
                    </select>
                </div>
                <div id="club-wrapper" class="hidden">
                    <label for="club-id" class="text-lg font-semibold text-white mb-2 block">Class / Club</label>
                    <select id="club-id" class="w-full text-lg p-3 rounded-lg bg-gray-600 text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 border border-gray-500"></select>
                </div>
            </div>
        </div>

        <div class="panel panel-body space-y-4">
            <div>
                <h2 class="section-heading">Problem Bank</h2>
                <p class="section-note">Attach an existing public problem or load one as an editable contest-only copy.</p>
            </div>
            <div class="flex flex-col md:flex-row md:items-end gap-4">
                <div class="flex-1">
                    <label for="existing-problem-id" class="text-lg font-semibold text-white mb-2 block">Existing Problem ID</label>
                    <input id="existing-problem-id" type="text"
                        class="w-full text-lg p-3 rounded-lg bg-gray-600 text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 border border-gray-500"
                        placeholder="e.g. 1">
                </div>
                <button type="button" id="add-existing-problem-button" class="btn">
                    Add Existing
                </button>
                <button type="button" id="load-existing-problem-button" class="btn btn-secondary">
                    Load as Inline
                </button>
            </div>
            <div id="existing-problem-list" class="grid grid-cols-1 lg:grid-cols-2 gap-3"></div>
        </div>

        <div class="panel panel-body space-y-4">
            <div class="flex items-center justify-between gap-4">
                <div>
                    <h2 class="section-heading">Contest-Only Problems</h2>
                    <p class="section-note">Problems created here can reuse IDs from other contests.</p>
                </div>
                <button type="button" id="add-inline-problem-button" class="btn">
                    Add Inline Problem
                </button>
            </div>
            <div id="inline-problems" class="space-y-4"></div>
        </div>

        <div class="text-center pt-2">
            <button type="submit" class="btn">
                Save Contest
            </button>
        </div>
    </form>
</div>
