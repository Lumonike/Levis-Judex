<link href="/admin/add-problem/sun-editor.css" rel="stylesheet" />
<script>
    window.contestEditorConfig = <%- JSON.stringify("contestEditorConfig" in locals ? contestEditorConfig : {}) %>;
</script>

<div class="mx-auto max-w-7xl space-y-6 text-left">
    <div class="flex flex-col gap-4 border-b border-gray-700 pb-6 lg:flex-row lg:items-end lg:justify-between">
        <div>
            <p class="text-sm font-semibold uppercase tracking-wide text-blue-300">Contest Builder</p>
            <h1 class="text-4xl font-bold text-white">Create or edit a contest</h1>
            <p class="mt-2 max-w-2xl text-gray-300">Set timing, access, points, and problems in one place.</p>
        </div>
        <div class="rounded-lg border border-gray-700 bg-gray-900 p-4">
            <p class="text-sm text-gray-400">Scoring</p>
            <p class="font-semibold text-white">Samples ignored, hidden tests split each problem's points.</p>
        </div>
    </div>

    <div class="rounded-lg border border-gray-700 bg-gray-900 p-5">
        <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-4 items-end">
            <%- include("../partials/input", { id: "contest-id-search", label: "Contest ID to Edit", type: "text", placeholder: "e.g. dec-2026" }) %>
            <button id="load-contest-button" class="text-lg px-4 py-3 rounded-lg bg-blue-500 text-white hover:bg-blue-600 focus:outline-none transition-colors duration-200 h-fit">
                Load Contest
            </button>
        </div>
    </div>

    <form id="contest-form" class="space-y-6">
        <div class="rounded-lg border border-gray-700 bg-gray-900 p-6 space-y-6">
            <div>
                <h2 class="text-2xl font-bold text-white">Contest Setup</h2>
                <p class="text-gray-400">These settings control availability and scoring windows.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <%- include("../partials/input", { id: "id", label: "Contest ID", type: "text", placeholder: "e.g. dec-2026" }) %>
                <%- include("../partials/input", { id: "name", label: "Contest Name", type: "text", placeholder: "December Contest" }) %>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label for="start-time" class="text-lg font-semibold text-white mb-2 block">Open Time</label>
                    <input type="datetime-local" id="start-time" required
                        class="w-full text-lg p-3 rounded-lg bg-gray-600 text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 border border-gray-500"/>
                </div>
                <div>
                    <label for="end-time" class="text-lg font-semibold text-white mb-2 block">Close Time</label>
                    <input type="datetime-local" id="end-time" required
                        class="w-full text-lg p-3 rounded-lg bg-gray-600 text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 border border-gray-500"/>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label for="timing-mode" class="text-lg font-semibold text-white mb-2 block">Timing Mode</label>
                    <select id="timing-mode" class="w-full text-lg p-3 rounded-lg bg-gray-600 text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 border border-gray-500">
                        <option value="global">Global window</option>
                        <option value="personal">Personal timer</option>
                    </select>
                </div>
                <div id="duration-wrapper" class="hidden">
                    <label for="duration-minutes" class="text-lg font-semibold text-white mb-2 block">Duration Minutes</label>
                    <input type="number" id="duration-minutes" min="1" value="240"
                        class="w-full text-lg p-3 rounded-lg bg-gray-600 text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 border border-gray-500"/>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label for="access-type" class="text-lg font-semibold text-white mb-2 block">Who Can Enter?</label>
                    <select id="access-type" class="w-full text-lg p-3 rounded-lg bg-gray-600 text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 border border-gray-500">
                        <option value="public">Anyone</option>
                        <option value="club">Class / club members</option>
                    </select>
                </div>
                <div id="club-wrapper" class="hidden">
                    <label for="club-id" class="text-lg font-semibold text-white mb-2 block">Class / Club</label>
                    <select id="club-id" class="w-full text-lg p-3 rounded-lg bg-gray-600 text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 border border-gray-500"></select>
                </div>
            </div>
        </div>

        <div class="rounded-lg border border-gray-700 bg-gray-900 p-6 space-y-4">
            <div>
                <h2 class="text-2xl font-bold text-white">Problem Bank</h2>
                <p class="text-gray-400">Attach an existing public problem or load one as an editable contest-only copy.</p>
            </div>
            <div class="flex flex-col md:flex-row md:items-end gap-4">
                <div class="flex-1">
                    <label for="existing-problem-id" class="text-lg font-semibold text-white mb-2 block">Existing Problem ID</label>
                    <input id="existing-problem-id" type="text"
                        class="w-full text-lg p-3 rounded-lg bg-gray-600 text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 border border-gray-500"
                        placeholder="e.g. 1">
                </div>
                <button type="button" id="add-existing-problem-button" class="text-lg px-4 py-3 rounded-lg bg-blue-500 text-white hover:bg-blue-600 focus:outline-none transition-colors duration-200">
                    Add Existing
                </button>
                <button type="button" id="load-existing-problem-button" class="text-lg px-4 py-3 rounded-lg bg-gray-600 text-white hover:bg-gray-500 focus:outline-none transition-colors duration-200">
                    Load as Inline
                </button>
            </div>
            <div id="existing-problem-list" class="grid grid-cols-1 lg:grid-cols-2 gap-3"></div>
        </div>

        <div class="rounded-lg border border-gray-700 bg-gray-900 p-6 space-y-4">
            <div class="flex items-center justify-between gap-4">
                <div>
                    <h2 class="text-2xl font-bold text-white">Contest-Only Problems</h2>
                    <p class="text-gray-400">Problems created here can reuse IDs from other contests.</p>
                </div>
                <button type="button" id="add-inline-problem-button" class="text-lg px-4 py-2 rounded-lg bg-blue-500 text-white hover:bg-blue-600 focus:outline-none transition-colors duration-200">
                    Add Inline Problem
                </button>
            </div>
            <div id="inline-problems" class="space-y-4"></div>
        </div>

        <div class="text-center pt-2">
            <button type="submit" class="text-lg px-5 py-3 rounded-lg bg-blue-500 text-white hover:bg-blue-600 focus:outline-none transition-colors duration-200">
                Save Contest
            </button>
        </div>
    </form>
</div>
