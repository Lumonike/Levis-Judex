<div class="mx-auto max-w-7xl space-y-6 text-left">
    <div class="flex flex-col gap-4 border-b border-gray-700 pb-6 lg:flex-row lg:items-end lg:justify-between">
        <div>
            <p class="text-sm font-semibold uppercase tracking-wide text-blue-300">Classes / Clubs</p>
            <h1 class="text-4xl font-bold text-white">Manage rosters and contests</h1>
            <p class="mt-2 max-w-2xl text-gray-300">Create a club, invite students, approve join requests, and build contests for your group.</p>
        </div>
        <a href="/contests" class="rounded-lg border border-gray-600 px-4 py-3 font-semibold text-blue-200 hover:bg-gray-700">View Contests</a>
    </div>

    <section class="grid grid-cols-1 gap-6 xl:grid-cols-[420px_1fr]">
        <form id="club-form" class="rounded-lg border border-gray-700 bg-gray-900 p-5 space-y-5">
            <div>
                <h2 class="text-2xl font-bold text-white">Create or Edit Club</h2>
                <p class="text-gray-400">The ID is used in URLs and contest settings.</p>
            </div>
            <div>
                <label for="club-id" class="block text-sm font-semibold text-gray-200">Club ID</label>
                <input id="club-id" required placeholder="e.g. math-team" class="mt-2 w-full rounded-lg border border-gray-600 bg-gray-800 p-3 text-white focus:border-blue-400 focus:outline-none">
            </div>
            <div>
                <label for="club-name" class="block text-sm font-semibold text-gray-200">Club Name</label>
                <input id="club-name" required placeholder="e.g. Math Team" class="mt-2 w-full rounded-lg border border-gray-600 bg-gray-800 p-3 text-white focus:border-blue-400 focus:outline-none">
            </div>
            <div>
                <label for="join-policy" class="block text-sm font-semibold text-gray-200">Join Policy</label>
                <select id="join-policy" class="mt-2 w-full rounded-lg border border-gray-600 bg-gray-800 p-3 text-white focus:border-blue-400 focus:outline-none">
                    <option value="invite">Invite or approval required</option>
                    <option value="open">Public to join</option>
                </select>
            </div>
            <button class="w-full rounded-lg bg-blue-500 px-4 py-3 font-semibold text-white hover:bg-blue-600">Save Club</button>
        </form>

        <div class="space-y-6">
            <section class="rounded-lg border border-gray-700 bg-gray-900 p-5">
                <div class="mb-4 flex items-center justify-between">
                    <div>
                        <h2 class="text-2xl font-bold text-white">Your Clubs</h2>
                        <p class="text-gray-400">Owned, joined, invited, requested, and public clubs appear here.</p>
                    </div>
                    <button id="refresh-clubs" class="rounded-lg border border-gray-600 px-4 py-2 font-semibold text-blue-200 hover:bg-gray-700">Refresh</button>
                </div>
                <div id="club-list" class="grid grid-cols-1 gap-4 lg:grid-cols-2"></div>
            </section>
        </div>
    </section>
</div>
