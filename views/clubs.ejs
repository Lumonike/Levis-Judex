<div class="page">
    <section class="page-header">
        <div>
            <p class="page-kicker">Clubs</p>
            <h1 class="page-title">Clubs</h1>
            <p class="page-subtitle">Join with an invite code, then use your club contests from one place.</p>
        </div>
        <a href="/contests" class="btn btn-secondary">View contests</a>
    </section>

    <section class="grid grid-cols-1 gap-5 lg:grid-cols-[360px_1fr]">
        <form id="join-code-form" class="panel panel-body space-y-4">
            <div>
            <h2 class="section-heading">Request club access</h2>
                <p class="section-note">Paste the code your teacher or club owner shared. Owners approve requests before you can enter.</p>
            </div>
            <div>
                <label for="invite-code">Invite code</label>
                <input id="invite-code" autocomplete="off" placeholder="ABCD1234">
            </div>
            <button class="btn w-full" type="submit">Request access</button>
        </form>

        <section class="panel panel-body">
            <div class="mb-5 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                <div>
                    <h2 class="section-heading">Your clubs</h2>
                </div>
                <button id="refresh-clubs" class="btn btn-secondary" type="button">Refresh</button>
            </div>
            <div id="club-list" class="grid grid-cols-1 gap-4 lg:grid-cols-2"></div>
        </section>
    </section>

    <details class="panel panel-body">
        <summary class="cursor-pointer font-semibold">Create a club</summary>
        <form id="club-form" class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-[1fr_1fr_auto] md:items-end">
            <div>
                <label for="club-id">Club ID</label>
                <input id="club-id" required placeholder="math-team">
            </div>
            <div>
                <label for="club-name">Club name</label>
                <input id="club-name" required placeholder="Math Team">
            </div>
            <button class="btn" type="submit">Save club</button>
        </form>
    </details>
</div>
