<div class="page narrow mx-auto">
    <section class="panel panel-body text-center">
        <p class="page-kicker">Contest</p>
        <h1 class="page-title"><%= typeof reason !== "undefined" ? reason.title : title %></h1>
        <p class="page-subtitle mx-auto"><%= typeof reason !== "undefined" ? reason.text : message %></p>
        <div class="mt-6">
            <a class="btn btn-secondary" href="<%= typeof contestID !== "undefined" ? `/contests/${contestID}` : "/contests" %>">Back to contests</a>
        </div>
    </section>
</div>
