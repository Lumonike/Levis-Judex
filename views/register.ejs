<div class="page narrow mx-auto">
    <section class="page-header">
        <div>
            <p class="page-kicker">Account</p>
            <h1 class="page-title">Create account</h1>
            <p class="page-subtitle">Register once, then join clubs and submit to contests.</p>
        </div>
    </section>

    <section class="panel panel-body">
        <form id="register-form" class="space-y-5">
            <%- include("partials/input", { id: "name", label: "Full name", type: "text", placeholder: "Ada Lovelace" }) %>
            <%- include("partials/input", { id: "email", label: "Email", type: "email", placeholder: "you@example.com" }) %>
            <%- include("partials/input", { id: "password", label: "Password", type: "password", placeholder: "Choose a password" }) %>
            <%- include("partials/button", { id: "register-button", text: "Create account" }) %>
        </form>
    </section>

    <p class="section-note text-center">
        Already registered? <a class="font-bold text-blue-700" href="/login">Sign in</a>
    </p>
</div>
