<div class="page narrow mx-auto">
    <section class="page-header">
        <div>
            <p class="page-kicker">Account</p>
            <% if (valid) { %>
                <h1 class="page-title">Set password</h1>
                <p class="page-subtitle">Choose a new password for your account.</p>
            <% } else { %>
                <h1 class="page-title">Invalid link</h1>
                <p class="page-subtitle">This reset link is invalid or expired.</p>
            <% } %>
        </div>
    </section>

    <% if (valid) { %>
        <section class="panel panel-body">
            <form id="complete-reset-form" class="space-y-5">
                <input id="reset-token" type="hidden" value="<%= token %>">
                <%- include("partials/input", { id: "password", label: "New Password", type: "password", placeholder: "New password" }) %>
                <%- include("partials/button", { id: "reset-button", text: "Reset password" }) %>
            </form>
        </section>
    <% } else { %>
        <a class="btn btn-secondary" href="/forgot-password">Request another link</a>
    <% } %>
</div>
