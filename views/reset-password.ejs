<div class="max-w-md mx-auto">
    <div class="text-center mb-8">
        <svg class="w-16 h-16 mx-auto mb-4 <%= valid ? "text-blue-400" : "text-red-400" %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
            />
        </svg>
        <% if (valid) { %>
            <h1 class="text-4xl font-bold text-white">Set New Password</h1>
            <p class="text-gray-400 mt-2">Choose a new password for your account</p>
        <% } else { %>
            <h1 class="text-4xl font-bold text-red-400">Invalid Link</h1>
            <p class="text-gray-400 mt-2">This reset link is invalid or expired.</p>
        <% } %>
    </div>

    <% if (valid) { %>
        <form id="complete-reset-form" class="space-y-6">
            <input id="reset-token" type="hidden" value="<%= token %>">
            <%- include("partials/input", { id: "password", label: "New Password", type: "password", placeholder: "Enter your new password" }) %>
            <%- include("partials/button", { id: "reset-button", text: "Reset Password" }) %>
        </form>
    <% } else { %>
        <div class="text-center">
            <a class="text-blue-400 hover:text-blue-300 font-semibold transition-colors duration-200" href="/forgot-password">Request another reset link</a>
        </div>
    <% } %>
</div>
