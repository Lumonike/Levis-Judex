<div class="page">
    <section class="page-header">
        <div>
            <p class="page-kicker">Contests</p>
            <h1 class="page-title">Contests</h1>
            <p class="page-subtitle">Choose a contest to view its problems and scoreboard.</p>
        </div>
    </section>

    <section class="list">
        <% if (contests.length === 0) { %>
            <div class="panel panel-body">
                <p class="section-note">No contests are available right now.</p>
            </div>
        <% } %>
        <% contests.forEach((contest, index) => { %>
            <a class="list-row" href="<%= contest.href %>">
                <div class="flex min-w-0 items-center gap-4">
                    <span class="id-pill"><%= index + 1 %></span>
                    <div class="min-w-0">
                        <p class="m-0 truncate font-medium"><%= contest.name %></p>
                        <p class="m-0 text-sm muted">
                            ID: <%= contest.id %> · <%= contest.startTime.toLocaleDateString() %> - <%= contest.endTime.toLocaleDateString() %>
                        </p>
                    </div>
                </div>
                <span class="muted text-right">
                    <%= contest.accessType === "club" ? `Club: ${contest.clubName ?? contest.clubId}` : "Public" %>
                </span>
            </a>
        <% }) %>
    </section>
</div>
