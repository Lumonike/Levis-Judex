<div class="page" data-contest-id="<%= contest.id %>" data-contest-club-id="<%= contest.clubId ?? "" %>" data-contest-status="<%= state.status %>">
    <section class="page-header">
        <div>
            <p class="page-kicker"><%= contest.accessType === "club" ? "Club contest" : "Contest" %></p>
            <h1 class="page-title"><%= contest.name %></h1>
        </div>
        <div class="panel panel-body min-w-64">
            <p class="section-note"><%= state.canSubmitForScore ? "Time remaining" : "Status" %></p>
            <p class="m-0 text-xl font-medium" id="contest-timing">Loading...</p>
        </div>
    </section>

    <% if (state.canStart) { %>
        <section class="panel panel-body flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div>
                <h2 class="section-heading">Start contest</h2>
                <p class="section-note">You will have <%= contest.durationMinutes %> minutes after you press Start.</p>
            </div>
            <button id="start-contest-button" class="btn" type="button">Start Contest</button>
        </section>
    <% } %>

    <% if (!state.canViewProblems && !state.canStart) { %>
        <section class="panel panel-body">
            <h2 class="section-heading"><%= state.isBeforeOpen ? "Not open yet" : "Closed" %></h2>
            <p class="section-note">
                <%= state.isBeforeOpen ? `This contest opens at ${contest.startTime.toLocaleString()}.` : "This personal contest is closed for new starts." %>
            </p>
        </section>
    <% } %>

    <% if (state.canViewProblems) { %>
        <section class="page">
            <div>
                <h2 class="section-heading">Problems</h2>
            </div>
            <div class="list">
                <% contest.problems.forEach((problem) => { %>
                    <a class="list-row" href="/contests/<%= contest.id %>/<%= problem.id %><%= contest.clubId ? `?club=${encodeURIComponent(contest.clubId)}` : "" %>">
                        <div class="flex min-w-0 items-center gap-4">
                            <span class="id-pill"><%= problem.id %></span>
                            <div class="min-w-0">
                                <p class="m-0 truncate font-medium"><%= problem.name %></p>
                                <p class="m-0 text-sm muted"><%= problem.points %> points</p>
                            </div>
                        </div>
                        <span class="muted">Solve</span>
                    </a>
                <% }) %>
            </div>
        </section>
    <% } %>

    <section class="panel panel-body">
        <div class="mb-4 flex items-center justify-between gap-3">
            <div>
                <h2 class="section-heading">Scoreboard</h2>
            </div>
        </div>
        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Rank</th>
                        <th>User</th>
                        <th>Solved</th>
                        <th>Points</th>
                        <th>Time</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (scoreboard.length === 0) { %>
                        <tr><td colspan="5" class="muted">No scored submissions yet.</td></tr>
                    <% } %>
                    <% scoreboard.forEach((row, index) => { %>
                        <tr>
                            <td><%= index + 1 %></td>
                            <td><%= row.email %></td>
                            <td><%= row.solved %></td>
                            <td><%= row.points %></td>
                            <td><%= row.elapsedLabel %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </section>
</div>

<script type="module" src="/contests/contest.js"></script>
<script type="module">
    import { apply } from "/contests/update-timing.js";
    const elem = document.getElementById("contest-timing");
    const startTime = new Date("<%= state.startsAt.toISOString() %>");
    const endTime = new Date("<%= state.endsAt.toISOString() %>");
    setInterval(apply, 100, elem, startTime, endTime);
</script>
