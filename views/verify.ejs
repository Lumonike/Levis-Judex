<div class="page narrow mx-auto">
    <section class="panel panel-body text-center">
        <% if (success) { %>
            <p class="page-kicker">Verified</p>
            <h1 class="page-title">Email verified</h1>
            <p class="page-subtitle mx-auto">Your account is ready.</p>
            <div class="mt-6"><a class="btn" href="/login">Sign in</a></div>
        <% } else { %>
            <p class="page-kicker">Verification</p>
            <h1 class="page-title">Invalid token</h1>
            <p class="page-subtitle mx-auto">Please register again to receive a fresh verification email.</p>
            <div class="mt-6"><a class="btn" href="/register">Register</a></div>
        <% } %>
    </section>
</div>
