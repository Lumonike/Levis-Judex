<div id="problem-context" data-problem-id="<%= problem.id %>" data-contest-id="<%= problem.contestID ?? "" %>"></div>

<div class="problem-page">
    <h1 class="problem-title"><%= problem.name %></h1>

    <div id="result"></div>

    <section class="problem-section">
        <%- problem.problemStatement %>
    </section>

    <section class="problem-section">
        <h2>Input Format</h2>
        <div><%- problem.inputFormat %></div>
    </section>

    <section class="problem-section">
        <h2>Output Format</h2>
        <div><%- problem.outputFormat %></div>
    </section>

    <% for (let i = 0; i < problem.numSampleTestcases; i++) { %>
        <section class="problem-section">
            <h2>Sample Input<%= problem.numSampleTestcases > 1 ? ` ${i + 1}` : "" %></h2>
            <div class="sample-block"><%= problem.inputTestcases[i] %></div>
        </section>
        <section class="problem-section">
            <h2>Sample Output<%= problem.numSampleTestcases > 1 ? ` ${i + 1}` : "" %></h2>
            <div class="sample-block"><%= problem.outputTestcases[i] %></div>
        </section>
    <% } %>

    <section class="problem-section">
        <h2>Submit</h2>
        <div id="container">
            <pre id="editor"></pre>
        </div>
        <div class="mt-4">
            <%- include("partials/button", { id: "submit-button", small: true, text: "Submit" }) %>
        </div>
    </section>
</div>

<style>
ul { list-style: disc; padding-left: 2.5rem; }
ol { list-style: decimal; padding-left: 2.5rem; }
</style>
