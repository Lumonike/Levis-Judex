<div class="page">
    <section class="page-header">
        <div>
            <p class="page-kicker">Problems</p>
            <h1 class="page-title">Problems</h1>
            <p class="page-subtitle">Choose a problem to solve.</p>
        </div>
    </section>

    <section class="list">
        <% if (problems.length === 0) { %>
            <div class="panel panel-body">
                <p class="section-note">No public problems are available yet.</p>
            </div>
        <% } %>
        <% problems.forEach((problem, index) => { %>
            <a class="list-row" href="/problems/<%= problem.id %>">
                <div class="flex min-w-0 items-center gap-4">
                    <span class="id-pill"><%= index + 1 %></span>
                    <div class="min-w-0">
                        <p class="m-0 truncate font-medium"><%= problem.name %></p>
                        <p class="m-0 text-sm muted">ID: <%= problem.id %></p>
                    </div>
                </div>
                <span class="muted">Open</span>
            </a>
        <% }) %>
    </section>
</div>
