<div class="page narrow mx-auto">
    <section class="page-header">
        <div>
            <p class="page-kicker">Account</p>
            <h1 class="page-title">Sign in</h1>
            <p class="page-subtitle">Continue to problems, contests, and club management.</p>
        </div>
    </section>

    <section class="panel panel-body">
        <form id="login-form" class="space-y-5">
            <%- include("partials/input", { id: "email", label: "Email", type: "email", placeholder: "you@example.com" }) %>
            <%- include("partials/input", { id: "password", label: "Password", type: "password", placeholder: "Your password" }) %>
            <div class="flex items-center justify-between gap-3">
                <a class="font-semibold text-blue-700" href="/forgot-password">Forgot password?</a>
                <%- include("partials/button", { id: "login-button", small: true, text: "Sign in" }) %>
            </div>
        </form>
    </section>

    <p class="section-note text-center">
        New here? <a class="font-bold text-blue-700" href="/register">Create an account</a>
    </p>
</div>
